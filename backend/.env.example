# Groq API key for AI Advisor (https://console.groq.com)
GROQ_API_KEY=gsk_your-key-here

# Supabase project credentials (https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Supabase JWT secret for auth (optional — leave unset to disable auth)
# Find in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Frontend URL for CORS (optional, for production)
FRONTEND_URL=https://your-frontend.vercel.app

# Langfuse AI observability (optional — leave unset to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
